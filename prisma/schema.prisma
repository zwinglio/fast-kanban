datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Board {
  id        String   @id @db.VarChar(12) // nanoid public slug (URL)
  title     String   @db.VarChar(255)
  prefix    String   @db.VarChar(16) // e.g. "PROJ"
  editHash  String   @map("edit_hash") @db.VarChar(255) // scrypt: salt:hash
  nextSeq   Int      @default(1) @map("next_seq") // per-board card counter
  createdAt DateTime @default(now()) @map("created_at")
  cards     Card[]
  tags      Tag[]
  columns   Column[]

  @@map("boards")
}

model Tag {
  id      Int    @id @default(autoincrement())
  boardId String @map("board_id") @db.VarChar(12)
  name    String @db.VarChar(50)
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   Card[]

  @@unique([boardId, name]) // no duplicate tag names per board
  @@map("tags")
}

model Column {
  id       Int    @id @default(autoincrement())
  boardId  String @map("board_id") @db.VarChar(12)
  name     String @db.VarChar(50)
  color    String @db.VarChar(7)
  position Int    @default(0)
  board    Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards    Card[]

  @@index([boardId])
  @@map("board_columns")
}

model Card {
  id        Int      @id @default(autoincrement())
  boardId   String   @map("board_id") @db.VarChar(12)
  seq       Int // display id = prefix + "-" + seq
  title     String   @db.VarChar(255)
  body      String?  @db.MediumText // markdown
  columnId  Int      @map("column_id")
  position  Int      @default(0) // order within a column
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column    Column   @relation(fields: [columnId], references: [id])
  tags      Tag[]

  @@unique([boardId, seq])
  @@index([boardId, columnId])
  @@map("cards")
}
